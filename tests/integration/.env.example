BASE_URL=http://localhost:5430
JWT_SECRET=mock_secret
LOG_LEVEL=DEBUG
ALLOW_UNSAFE=TRUE

# Database test container.
#
CSC_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres-csc:5432/metadata_submitter
NBIS_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres-nbis:5432/metadata_submitter

# Keystone test container.
#
KEYSTONE_ENDPOINT=http://mockkeystone:5001

# LDAP test container.
#
CSC_LDAP_HOST=ldap://mockldap # set to ldap://localhost if running with honcho
CSC_LDAP_USER=cn=admin,dc=csc,dc=fi
CSC_LDAP_PASSWORD=admin

# Auth mock container.
#
OIDC_URL=http://mockauth:8000
OIDC_REDIRECT_URL=http://localhost:3000/home
OIDC_CLIENT_ID=aud2
OIDC_CLIENT_SECRET=secret_must_be_long
OIDC_SECURE_COOKIE=FALSE
OIDC_VERIFY_ID_TOKEN=False
# OIDC_SECURE_COOKIE and OIDC_VERIFY_ID_TOKEN must be removed or set to TRUE in production.

# Admin mock container.
#
ADMIN_URL=http://mockadmin:8004

# Bigpicture deployment.
#
BP_CENTER_ID=bb
JWT_ISSUER=https://login.bp.nbis.se
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nMFkwEwYHKoZIzj0CAQYIKoZIzj0DAQcDQgAE6BHPFd3O+PQMz/gg3G40bNGcHvX4\nFTpaPcRS3UJ6Akk281GAZLc0VsttfXhbaDsP+72J60Ff93nM5UR6I9pxsg==\n-----END PUBLIC KEY-----\n
JWT_ALGORITHM=ES256
